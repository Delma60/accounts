{
  "name": "gateway-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "echo 'Launch local service cluster here'",
    "build": "npm run build --workspace packages/tsconfig && npm run build --workspace packages/types && npm run build --workspace packages/utils",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@spurs-baas/sdk": "^1.0.0",
    "argon2": "^0.44.0",
    "fastify": "^5.8.5",
    "jose": "^6.2.3",
    "node": "^26.3.0",
    "otplib": "^13.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
