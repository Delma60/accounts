{
  "name": "gateway-monorepo",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "gateway-monorepo",
      "version": "1.0.0",
      "workspaces": [
        "apps/*",
        "services/*",
        "packages/*"
      ]
    },
    "apps/accounts-ui": {
      "name": "@app/accounts-ui",
      "version": "1.0.0"
    },
    "node_modules/@app/accounts-ui": {
      "resolved": "apps/accounts-ui",
      "link": true
    },
    "node_modules/@app/api": {
      "resolved": "services/api",
      "link": true
    },
    "node_modules/@app/auth": {
      "resolved": "services/auth",
      "link": true
    },
    "node_modules/@app/types": {
      "resolved": "packages/types",
      "link": true
    },
    "node_modules/@app/utils": {
      "resolved": "packages/utils",
      "link": true
    },
    "node_modules/@app/worker": {
      "resolved": "services/worker",
      "link": true
    },
    "packages/types": {
      "name": "@app/types",
      "version": "1.0.0"
    },
    "packages/utils": {
      "name": "@app/utils",
      "version": "1.0.0"
    },
    "services/api": {
      "name": "@app/api",
      "version": "1.0.0"
    },
    "services/auth": {
      "name": "@app/auth",
      "version": "1.0.0"
    },
    "services/worker": {
      "name": "@app/worker",
      "version": "1.0.0"
    }
  }
}
